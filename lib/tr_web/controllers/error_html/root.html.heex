<!DOCTYPE html>
<html lang="en" style="scrollbar-gutter: stable;">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <% description =
      gettext(
        "Welcome to SegFault blog! This page is dedicated to documenting and exploring various
               technologies. Our blog is hosted on a k3s cluster in OCI, powered by Elixir and Phoenix. Dive in to
               discover insights, tutorials, and experiments across the tech landscape."
      ) %>
    <meta name="description" content={description} />
    <meta property="og:title" content={assigns[:page_title] || "SegFault"} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={url(~p"/images/segfault.webp")} />

    <link rel="icon" type="image/svg+xml" href={~p"/favicon.svg"} />
    <link rel="icon" type="image/x-icon" href={~p"/favicon.ico"} />
    <link rel="icon" type="image/png" sizes="32x32" href={~p"/favicon-32x32.png"} />
    <link rel="icon" type="image/png" sizes="16x16" href={~p"/favicon-16x16.png"} />
    <link rel="apple-touch-icon" sizes="180x180" href={~p"/apple-touch-icon.png"} />

    <.live_title>
      {assigns[:page_title] || "SegFault"}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>
  </head>
  <body class="bg-terminal-50 dark:bg-terminal-900 dark:text-white font-sans antialiased">
    <header class="dark:bg-terminal-900 dark:text-white">
      <section class="p-4">
        <.link navigate="/#{Gettext.get_locale(TrWeb.Gettext)}/" class="no-underline inline-block">
          <div class="logo-full">
            <div class="logo-addr">0x0000DEAD</div>
            <div class="logo-main">
              <span class="logo-prompt">$</span><span class="logo-wordmark">segfault</span><span class="logo-cursor"></span>
            </div>
            <div class="logo-bottom">
              <span class="logo-signal">SIGSEGV (11) -- core dumped</span>
              <span class="logo-pw">.pw</span>
            </div>
          </div>
        </.link>
      </section>
    </header>

    <main class="sm:px-6 lg:px-8 min-h-[70vh]">
      <div class="mx-auto max-w-screen-2xl border border-terminal-300 dark:border-terminal-600 p-8">
        {@inner_content}
      </div>
    </main>
  </body>

  <footer class="bg-terminal-900 dark:bg-terminal-950 text-terminal-400 text-center py-4">
    <article class="column text-sm">
      <ul>
        <li>
          <a href={"https://segfault.pw/#{Gettext.get_locale(TrWeb.Gettext)}/blog"}>
            This blog
          </a>
        </li>
        <li>
          <a href="https://github.com/kainlite/tr">Github repository</a>
        </li>
        <li>
          <a href="https://twitter.com/kainlite">Twitter @kainlite</a>
        </li>
        <li>
          <.link
            rel="alternate"
            type="application/rss+xml"
            title="Blog Title"
            navigate={~p"/index.xml"}
          >
            RSS
          </.link>
        </li>
        <li>
          <.link navigate={~p"/#{Gettext.get_locale(TrWeb.Gettext)}/privacy"}>
            Privacy policy
          </.link>
        </li>
      </ul>
    </article>
    <p class="text-base">© 2021 SegFault</p>
  </footer>
</html>
