<!DOCTYPE html>
<html lang="en" style="scrollbar-gutter: stable;">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <% default_description =
      gettext("Learn about DevOps, Linux, Containers, Kubernetes, CI/CD, AWS,
       Terraform, Docker, and more. Explore insights,
       tutorials, and experiments.") %>
    <% og_desc = assigns[:og_description] || default_description %>
    <% og_title = assigns[:page_title] || "SegFault" %>
    <% og_image = assigns[:og_image] || url(~p"/images/segfault.webp") %>
    <% og_url = assigns[:og_url] || "https://segfault.pw" %>
    <% og_type = assigns[:og_type] || "website" %>

    <meta name="description" content={og_desc} />

    <meta property="og:title" content={og_title} />
    <meta property="og:description" content={og_desc} />
    <meta property="og:image" content={og_image} />
    <meta property="og:url" content={og_url} />
    <meta property="og:type" content={og_type} />
    <meta property="og:site_name" content="SegFault" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={og_title} />
    <meta name="twitter:description" content={og_desc} />
    <meta name="twitter:image" content={og_image} />

    <link rel="canonical" href={og_url} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="SegFault RSS"
      href={url(~p"/index.xml")}
    />

    <%= if assigns[:og_url] do %>
      <script type="application/ld+json">
        <%= raw(Jason.encode!(%{
          "@context" => "https://schema.org",
          "@type" => "TechArticle",
          "headline" => og_title,
          "description" => assigns[:og_description],
          "image" => og_image,
          "url" => assigns[:og_url],
          "datePublished" => assigns[:og_date_published],
          "author" => %{"@type" => "Person", "name" => "Gabriel Garrido"},
          "publisher" => %{"@type" => "Organization", "name" => "SegFault"}
        })) %>
      </script>
    <% end %>

    <.live_title>
      {assigns[:page_title] || "SegFault"}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>
  </head>
  <body class="bg-terminal-50 dark:bg-terminal-900 dark:text-zinc-200 font-sans antialiased">
    {@inner_content}
    <script
      data-name="BMC-Widget"
      data-cfasync="false"
      src="https://cdnjs.buymeacoffee.com/1.0.0/widget.prod.min.js"
      data-id="kainlite"
      data-description="Support me on Buy me a coffee!"
      data-message=""
      data-color="#00ff41"
      data-position="Right"
      data-x_margin="18"
      data-y_margin="18"
    >
    </script>
  </body>

  <footer class="bg-terminal-900 dark:bg-terminal-950 text-terminal-400 py-12 border-t border-terminal-600 dark:border-terminal-600">
    <div class="max-w-screen-xl mx-auto px-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8 mb-8">
        <div>
          <div class="flex items-center gap-3 mb-4">
            <img
              src={~p"/images/segfault.webp"}
              alt="SegFault"
              class="w-10 h-10 rounded-full"
            />
            <div>
              <h3 class="text-accent dark:text-accent font-mono font-semibold text-lg">Gabriel Garrido</h3>
            </div>
          </div>
          <p class="text-terminal-400 text-sm leading-relaxed">
            DevOps Engineer & Cloud Architect. Writing about Linux, Kubernetes, and cloud technologies.
          </p>
        </div>
        <div>
          <h3 class="text-accent dark:text-accent font-mono font-semibold text-lg mb-4">Navigation</h3>
          <ul class="space-y-2">
            <li class="list-none">
              <a
                href={"https://segfault.pw/#{Gettext.get_locale(TrWeb.Gettext)}/blog"}
                class="text-terminal-400 hover:text-accent dark:hover:text-accent transition-colors"
              >
                Blog
              </a>
            </li>
            <li class="list-none">
              <.link
                navigate={~p"/#{Gettext.get_locale(TrWeb.Gettext)}/about"}
                class="text-terminal-400 hover:text-accent dark:hover:text-accent transition-colors"
              >
                About
              </.link>
            </li>
            <li class="list-none">
              <.link
                navigate={~p"/#{Gettext.get_locale(TrWeb.Gettext)}/privacy"}
                class="text-terminal-400 hover:text-accent dark:hover:text-accent transition-colors"
              >
                Privacy Policy
              </.link>
            </li>
            <li class="list-none">
              <.link
                rel="alternate"
                type="application/rss+xml"
                title="SegFault RSS"
                navigate={~p"/index.xml"}
                class="text-terminal-400 hover:text-accent dark:hover:text-accent transition-colors"
              >
                RSS Feed
              </.link>
            </li>
          </ul>
        </div>
        <div>
          <h3 class="text-accent dark:text-accent font-mono font-semibold text-lg mb-4">Connect</h3>
          <ul class="space-y-2">
            <li class="list-none">
              <a
                href="https://github.com/kainlite/tr"
                class="text-terminal-400 hover:text-accent dark:hover:text-accent transition-colors"
              >
                GitHub
              </a>
            </li>
            <li class="list-none">
              <a
                href="https://www.linkedin.com/in/gabrielgarrido/"
                class="text-terminal-400 hover:text-accent dark:hover:text-accent transition-colors"
              >
                LinkedIn
              </a>
            </li>
            <li class="list-none">
              <a
                href="https://twitter.com/kainlite"
                class="text-terminal-400 hover:text-accent dark:hover:text-accent transition-colors"
              >
                Twitter
              </a>
            </li>
            <li class="list-none">
              <a
                href="https://github.com/sponsors/kainlite"
                class="text-terminal-400 hover:text-accent dark:hover:text-accent transition-colors"
              >
                GitHub Sponsors
              </a>
            </li>
            <li class="list-none">
              <a
                href="https://buymeacoffee.com/kainlite"
                class="text-terminal-400 hover:text-accent dark:hover:text-accent transition-colors"
              >
                Buy Me a Coffee
              </a>
            </li>
          </ul>
        </div>
        <div>
          <h3 class="text-accent dark:text-accent font-mono font-semibold text-lg mb-4">Stay Updated</h3>
          <p class="text-terminal-400 text-sm leading-relaxed mb-4">
            Register for an account to get email notifications when new posts are published.
          </p>
          <a
            href={~p"/users/register"}
            class="inline-flex items-center gap-2 px-4 py-2 bg-accent-light dark:bg-accent text-white dark:text-terminal-900 text-sm font-mono font-medium rounded-none hover:bg-accent-dark dark:hover:bg-accent-muted transition-colors"
          >
            Register
          </a>
        </div>
      </div>
      <div class="border-t border-terminal-600 dark:border-terminal-600 pt-8 text-center">
        <p class="text-terminal-400 text-sm">© 2021-2026 SegFault. Built with Phoenix & Elixir.</p>
      </div>
    </div>
  </footer>
</html>
