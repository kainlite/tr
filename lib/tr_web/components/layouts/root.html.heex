<!DOCTYPE html>
<html lang="en" style="scrollbar-gutter: stable;">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <% default_description =
      gettext("Learn about DevOps, Linux, Containers, Kubernetes, CI/CD, AWS,
       Terraform, Docker, and more. Explore insights,
       tutorials, and experiments.") %>
    <% og_desc = assigns[:og_description] || default_description %>
    <% og_title = assigns[:page_title] || "SegFault" %>
    <% og_image = assigns[:og_image] || url(~p"/images/segfault.webp") %>
    <% og_url = assigns[:og_url] || "https://segfault.pw" %>
    <% og_type = assigns[:og_type] || "website" %>

    <meta name="description" content={og_desc} />

    <meta property="og:title" content={og_title} />
    <meta property="og:description" content={og_desc} />
    <meta property="og:image" content={og_image} />
    <meta property="og:url" content={og_url} />
    <meta property="og:type" content={og_type} />
    <meta property="og:site_name" content="SegFault" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={og_title} />
    <meta name="twitter:description" content={og_desc} />
    <meta name="twitter:image" content={og_image} />

    <link rel="canonical" href={og_url} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="SegFault RSS"
      href={url(~p"/index.xml")}
    />

    <%= if assigns[:og_url] do %>
      <script type="application/ld+json">
        <%= raw(Jason.encode!(%{
          "@context" => "https://schema.org",
          "@type" => "TechArticle",
          "headline" => og_title,
          "description" => assigns[:og_description],
          "image" => og_image,
          "url" => assigns[:og_url],
          "datePublished" => assigns[:og_date_published],
          "author" => %{"@type" => "Person", "name" => "Gabriel Garrido"},
          "publisher" => %{"@type" => "Organization", "name" => "SegFault"}
        })) %>
      </script>
    <% end %>

    <.live_title>
      {assigns[:page_title] || "SegFault"}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>
  </head>
  <body class="bg-terminal-50 dark:bg-terminal-900 dark:text-zinc-200 font-sans antialiased">
    {@inner_content}
    <script
      data-name="BMC-Widget"
      data-cfasync="false"
      src="https://cdnjs.buymeacoffee.com/1.0.0/widget.prod.min.js"
      data-id="kainlite"
      data-description="Support me on Buy me a coffee!"
      data-message=""
      data-color="#00ff41"
      data-position="Right"
      data-x_margin="18"
      data-y_margin="18"
    >
    </script>
  </body>
</html>
